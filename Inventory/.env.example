SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host/your-db?sslmode=require
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_JPA_SHOW_SQL=false
PORT=8080
CRYPTO_VAULT_MASTER_KEY=change-this-to-a-long-random-secret
GEMINI_API_KEY=
# GOOGLE_API_KEY= is also accepted as an alias for Gemini on Render
GEMINI_MODEL=gemini-3.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
CRYPTOQUANT_API_KEY=
GLASSNODE_API_KEY=
WHALE_ALERT_API_KEY=
CRYPTO_AUTONOMOUS_PAPER_ENABLED=true
